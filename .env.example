# Directory on the host where uploaded music files will be stored
UPLOADS_DIR=/path/to/uploads

# Directory on the host where the SQLite database will be stored
DB_DIR=/path/to/data

# Directory on the host where a backup.zip can be placed for server-side restore
RESTORE_DIR=/path/to/restore

# Host ports (change if defaults conflict with other services)
FRONTEND_PORT=8080
BACKEND_PORT=5000
